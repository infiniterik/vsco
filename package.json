{
  "name": "react-byok",
  "displayName": "ReAct BYOK",
  "description": "Run a no-tool-calling LLM as a ReAct agent via VS Code agent hooks.",
  "version": "0.1.3",
  "publisher": "react-byok",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/infiniterik/vsco.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "react-byok.setup",
        "title": "ReAct BYOK: Set up in this workspace"
      }
    ]
  },
  "scripts": {
    "build": "tsc",
    "vscode:prepublish": "npm run build",
    "package": "npm run build && vsce package --out react-byok.vsix",
    "test": "node --import tsx --test test/*.test.ts",
    "inject": "tsx src/hooks/inject-catalog.ts",
    "step": "tsx src/hooks/react-step.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
