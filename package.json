{
  "name": "react-byok",
  "displayName": "ReAct BYOK",
  "description": "Run a no-tool-calling LLM as a ReAct agent via VS Code agent hooks.",
  "version": "0.1.8",
  "publisher": "react-byok",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/infiniterik/vsco.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "react-byok.setup",
        "title": "ReAct BYOK: Set up in this workspace"
      },
      {
        "command": "react-byok.showOutput",
        "title": "ReAct BYOK: Show tool output"
      },
      {
        "command": "react-byok.regatherContext",
        "title": "ReAct BYOK: Re-gather document context"
      }
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "bundle": "node esbuild.mjs",
    "build": "npm run typecheck && npm run bundle",
    "vscode:prepublish": "npm run build",
    "package": "npm run build && vsce package --out react-byok.vsix",
    "test": "node --import tsx --test test/*.test.ts",
    "inject": "tsx src/hooks/inject-catalog.ts",
    "step": "tsx src/hooks/react-step.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.2",
    "pdfjs-dist": "^4.10.38",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
